{
  "name": "mw-craft",
  "version": "1.0.0",
  "description": "MW Craft multiplayer RTS game",
  "main": "server.js",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "generate:map-image": "node scripts/generate-map-image.js",
    "auto-commit": "node scripts/auto-commit.js",
    "auto-commit:push": "node scripts/auto-commit.js --push",
    "auto-commit:start": "powershell -ExecutionPolicy Bypass -File scripts/start-auto-commit.ps1",
    "auto-commit:start:push": "powershell -ExecutionPolicy Bypass -File scripts/start-auto-commit.ps1 -Push",
    "auto-commit:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-auto-commit.ps1"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "better-sqlite3": "^9.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
